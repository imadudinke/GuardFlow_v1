# GuardFlow Backend - Environment Configuration

# Database
DATABASE_URL=postgresql://guardflow:your_secure_password@postgres:5432/guardflow_db

# Redis
REDIS_URL=redis://redis:6379

# Security
SECRET_KEY=your-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS
# Comma-separated frontend origins. Do not use "*" when credentials/cookies are enabled.
CORS_ORIGINS=http://localhost:3000,https://guard-flow-v1.vercel.app

# Auth cookie behavior (for cross-site frontend/backend deployments)
# In production with separate domains (e.g. Vercel + Render), use SameSite=None and secure cookies.
COOKIE_SAMESITE=none
COOKIE_SECURE=true
# Optional: set only if you need a specific domain attribute
# COOKIE_DOMAIN=
# Temporary auth troubleshooting endpoint at /api/v1/auth/debug-cookie
AUTH_DEBUG_COOKIE=false

# Environment
ENVIRONMENT=development

# Render Keep-Alive (prevents free tier from sleeping)
# Set this to your Render service URL in production
RENDER_EXTERNAL_URL=https://guardflow-v1.onrender.com
