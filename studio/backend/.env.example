# GuardFlow Backend - Environment Configuration

# Database
DATABASE_URL=postgresql://guardflow:your_secure_password@postgres:5432/guardflow_db

# Redis
REDIS_URL=redis://redis:6379

# Security
SECRET_KEY=your-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS
# Comma-separated frontend origins. Do not use "*" when credentials/cookies are enabled.
CORS_ORIGINS=http://localhost:3000,https://guard-flow-v1.vercel.app

# Environment
ENVIRONMENT=development
