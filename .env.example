# GuardFlow Studio - Environment Configuration
# Copy this file to .env and update with your values

# ============================================
# DATABASE CONFIGURATION
# ============================================
DATABASE_URL=postgresql://guardflow:your_secure_password@postgres:5432/guardflow_db
# For production, use a strong password and consider using connection pooling
# Example: postgresql://user:pass@host:5432/dbname?sslmode=require

# ============================================
# REDIS CONFIGURATION
# ============================================
REDIS_URL=redis://redis:6379
# For production with password: redis://:password@host:6379
# For Redis cluster: redis://host1:6379,host2:6379,host3:6379

# ============================================
# BACKEND SECURITY
# ============================================
# Generate with: openssl rand -hex 32
SECRET_KEY=your-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,https://studio.guardflow.dev

# ============================================
# FRONTEND CONFIGURATION
# ============================================
NEXT_PUBLIC_API_URL=http://localhost:8001
# For production: https://api.guardflow.dev

# ============================================
# DEPLOYMENT ENVIRONMENT
# ============================================
ENVIRONMENT=development
# Options: development, staging, production

# ============================================
# OPTIONAL: EMAIL CONFIGURATION (for notifications)
# ============================================
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM=noreply@guardflow.dev

# ============================================
# OPTIONAL: MONITORING & LOGGING
# ============================================
# SENTRY_DSN=https://your-sentry-dsn
# LOG_LEVEL=INFO
# LOG_FORMAT=json

# ============================================
# OPTIONAL: RATE LIMITING
# ============================================
# API_RATE_LIMIT=100
# API_RATE_WINDOW=60

# ============================================
# DOCKER COMPOSE OVERRIDES
# ============================================
# PostgreSQL
POSTGRES_USER=guardflow
POSTGRES_PASSWORD=your_secure_password
POSTGRES_DB=guardflow_db

# Ports (change if needed)
BACKEND_PORT=8001
FRONTEND_PORT=3000
POSTGRES_PORT=5432
REDIS_PORT=6379
